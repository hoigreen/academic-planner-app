VITE_API_URL=http://localhost:8080

# Keycloak server — must be a DIFFERENT port from the .NET API.
# Default Keycloak standalone port is 8180, Docker default is 8080.
# Adjust the port to match your actual Keycloak instance.
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=academic-planner
VITE_KEYCLOAK_CLIENT_ID=academic-planner-web